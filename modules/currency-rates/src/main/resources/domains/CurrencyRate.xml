<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://axelor.com/xml/ns/domain-models
               http://axelor.com/xml/ns/domain-models/domain-models_7.0.xsd">
    <module name="currency-rates" package="com.axelor.apps.currencyrates.db"/>
    <entity name="CurrencyRate">
        <string  name="code"     title="Code"       required="true" max="10"/>
        <string  name="name"     title="Name"       required="true" max="100"/>
        <integer name="nominal"  title="Nominal"    required="true"/>
        <decimal name="rate"     title="Rate (KGS)" required="true" precision="18" scale="6"/>
        <date    name="rateDate" title="Date"       required="true"/>
        <unique-constraint columns="code,rate_date"/>
    </entity>
</domain-models>
