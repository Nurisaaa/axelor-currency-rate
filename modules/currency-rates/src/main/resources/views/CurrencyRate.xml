<?xml version="1.0" encoding="UTF-8"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views
              http://axelor.com/xml/ns/object-views/object-views_7.0.xsd">

  <grid name="currency-rate-grid" title="Currency Rates"
    model="com.axelor.apps.currencyrates.db.CurrencyRate" orderBy="-rateDate,code">
    <toolbar>
      <button name="btnUpdate" title="Update Rates" onClick="action-currency-rate-update"
        icon="fa-refresh"/>
    </toolbar>
    <field name="rateDate" width="120"/>
    <field name="code" width="80"/>
    <field name="name"/>
    <field name="nominal" width="80"/>
    <field name="rate" width="120"/>
  </grid>

  <form name="currency-rate-form" title="Currency Rate"
    model="com.axelor.apps.currencyrates.db.CurrencyRate">
    <panel title="Currency Rate">
      <field name="rateDate" colSpan="4"/>
      <field name="code" colSpan="4"/>
      <field name="name" colSpan="4"/>
      <field name="nominal" colSpan="4"/>
      <field name="rate" colSpan="4"/>
    </panel>
  </form>

  <action-method name="action-currency-rate-update">
    <call class="com.axelor.apps.currencyrates.web.CurrencyRateController" method="updateRates"/>
  </action-method>

  <action-view name="action-currency-rate-grid" title="Currency Rates"
    model="com.axelor.apps.currencyrates.db.CurrencyRate">
    <view type="grid" name="currency-rate-grid"/>
    <view type="form" name="currency-rate-form"/>
  </action-view>

  <menuitem name="menu-currency-rate" title="Currency Rates" parent="referential-root"
    action="action-currency-rate-grid" order="100"/>

</object-views>